{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "Default capabilities for AnyAI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" },
        { "url": "https://*/*" }
      ]
    },
    "dialog:default"
  ]
}
